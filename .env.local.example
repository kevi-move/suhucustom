# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://jgcjlqhluegdcqjaskau.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only: required for /admin/inquiries to list submissions (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: bypass login during development
# NEXT_PUBLIC_ADMIN_BYPASS=true
# NEXT_PUBLIC_ADMIN_BYPASS_EMAIL=admin@suhucustom.local

# --- Local admin gate (no Supabase auth for entering /admin) ---
# When true, /admin requires a server-configured username/password and sets an HttpOnly cookie.
# NEXT_PUBLIC_ADMIN_LOCAL_GATE=true
# ADMIN_LOCAL_USERNAME=your_admin_username
# ADMIN_LOCAL_PASSWORD=your_strong_password
# ADMIN_LOCAL_SECRET=at_least_16_chars_random_secret_for_cookie_signing
# Optional: email string stored with CMS edits / displayed in admin sidebar
# ADMIN_LOCAL_IDENTITY_EMAIL=admin@your-domain.com
# NEXT_PUBLIC_ADMIN_LOCAL_DISPLAY_EMAIL=admin@your-domain.com

# Optional: frontend site root URL (used by preview links)
# NEXT_PUBLIC_FRONTEND_URL=https://your-main-site.com

# Public site URL for absolute links, SEO, sitemap (required in production)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# WhatsApp contact (digits only, country code included). Falls back to /contact-us if unset.
# NEXT_PUBLIC_WHATSAPP_NUMBER=8613800138000

# Inquiry email notifications (Resend)
# 1. Register at https://resend.com → API Keys → create key
# 2. For testing: leave INQUIRY_FROM_EMAIL as onboarding@resend.dev (default in code)
# 3. After you buy a domain: verify it in Resend → use no-reply@yourdomain.com
NOTIFY_TO_EMAIL=suhujing3@gmail.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# INQUIRY_FROM_EMAIL=Suhu Custom <onboarding@resend.dev>
# Production (after domain verified in Resend):
# INQUIRY_FROM_EMAIL=Suhu Custom <no-reply@yourdomain.com>

# OpenAI Images API (scripts/openai-generate-images.mjs)
# Get key: https://platform.openai.com/api-keys  (separate from ChatGPT Plus)
OPENAI_API_KEY=sk-proj-your_key_here
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_IMAGE_SIZE=1536x1024
# OPENAI_IMAGE_QUALITY=medium

# DeepL — multilingual auto-translation (https://www.deepl.com/pro-api)
# Free tier: 500,000 chars/month at https://www.deepl.com/pro-api (key ends with :fx uses api-free.deepl.com)
DEEPL_API_KEY=your_deepl_key_here
# Optional override:
# DEEPL_API_URL=https://api-free.deepl.com/v2

# Redirect URLs should include:
# http://localhost:3000/auth/callback
# https://your-domain.com/auth/callback
